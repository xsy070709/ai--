DEEPSEEK_API_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_CHAT_MODEL=deepseek-v4-flash
DEEPSEEK_STRUCTURED_MODEL=deepseek-v4-flash
DEEPSEEK_THINKING=disabled
DEEPSEEK_CHAT_MAX_TOKENS=700
DEEPSEEK_STRUCTURED_MAX_TOKENS=900
STRUCTURED_PROVIDER=deepseek
LOCAL_LM_BASE_URL=http://127.0.0.1:7985/v1
LOCAL_LM_API_KEY=lm-studio
LOCAL_STRUCTURED_MODEL=google/gemma-4-12b-qat
LOCAL_EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2
LLM_FORCE_LOCAL=false
MEMORY_EXTRACTOR=rule
MEMORY_INTENT_CLASSIFIER=rule
APP_DATA_DIR=data
